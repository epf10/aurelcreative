---
interface Props {
  size?: number;
  animated?: boolean;
  class?: string;
}

const { size = 30, animated = false, class: className } = Astro.props;
---

<svg
  class:list={[{ animated }, className]}
  width={size}
  height={size}
  viewBox="0 0 96 96"
  aria-hidden="true"
>
  <path
    class="shape"
    style="--d: 0s"
    d="M25 4 H25 A21 21 0 0 1 46 25 V38 A8 8 0 0 1 38 46 H12 A8 8 0 0 1 4 38 V25 A21 21 0 0 1 25 4 Z"
    fill="#0057FF"></path>
  <path
    class="shape"
    style="--d: 0.12s"
    d="M60 4 H82 A10 10 0 0 1 92 14 V36 A10 10 0 0 1 82 46 H60 A10 10 0 0 1 50 36 V14 A10 10 0 0 1 60 4 Z"
    fill="#FF2D9B"></path>
  <path
    class="shape"
    style="--d: 0.24s"
    d="M12 50 H38 A8 8 0 0 1 46 58 V71 A21 21 0 0 1 25 92 H25 A21 21 0 0 1 4 71 V58 A8 8 0 0 1 12 50 Z"
    fill="#FFE000"></path>
  <circle class="shape" style="--d: 0.36s" cx="71" cy="71" r="21" fill="#00C853"></circle>
</svg>

<style>
  .animated .shape {
    transform-origin: center;
    transform-box: fill-box;
    animation:
      pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) var(--d) both,
      drift 6s ease-in-out calc(1s + var(--d)) infinite alternate;
  }

  @keyframes pop {
    from {
      opacity: 0;
      transform: scale(0.4);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes drift {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-5px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .animated .shape {
      animation: none;
    }
  }
</style>
