---
import { Image } from 'astro:assets';
import mark from '../assets/logos/AC_Logo_Mark.png';

interface Props {
  size?: number;
  animated?: boolean;
  class?: string;
}

const { size = 330, animated = false, class: className } = Astro.props;
---

<Image
  src={mark}
  alt=""
  class:list={[{ animated }, className]}
  width={size}
  height={Math.round(size * (mark.height / mark.width))}
  densities={[1, 2]}
  loading="eager"
/>

<style>
  .animated {
    animation:
      pop 0.7s cubic-bezier(0.34, 1.56, 0.64, 1) both,
      drift 6s ease-in-out 1.2s infinite alternate;
  }

  @keyframes pop {
    from {
      opacity: 0;
      transform: scale(0.5);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes drift {
    from {
      transform: translateY(0);
    }
    to {
      transform: translateY(-6px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .animated {
      animation: none;
    }
  }
</style>
