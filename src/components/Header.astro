---
import Brand from './Brand.astro';
---

<header>
  <div class="wrap nav">
    <Brand />
    <nav class="nav-cta" aria-label="Primary">
      <a class="btn btn-ghost" href="#how">How it works</a>
      <a class="btn btn-primary" href="#apply">Apply to partner</a>
    </nav>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }

  .nav-cta {
    display: flex;
    gap: 0.6rem;
    align-items: center;
  }

  .nav-cta .btn {
    padding: 0.6rem 1.15rem;
    font-size: 0.92rem;
  }

  @media (max-width: 880px) {
    .nav-cta .btn-ghost {
      display: none;
    }
  }
</style>
