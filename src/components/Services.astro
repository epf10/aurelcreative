---
import { Image } from 'astro:assets';
import { services } from '../data/site';
import markBlue from '../assets/logos/mark-blue.png';
import markPink from '../assets/logos/mark-pink.png';
import markYellow from '../assets/logos/mark-yellow.png';
import markGreen from '../assets/logos/mark-green.png';

// Logo-mark shapes in the same order as `services` (blue, pink, yellow, green)
// so each card shows its color as the exact shape it is in the logo.
const marks = [markBlue, markPink, markYellow, markGreen];
---

<section class="pad" id="what">
  <div class="wrap">
    <p class="eyebrow reveal">What we do</p>
    <h2 class="reveal">Done for you, built around you.</h2>
    <div class="cards">
      {
        services.map((service, i) => (
          <article class="card reveal" style={`--reveal-delay: ${i * 90}ms`}>
            <Image src={marks[i]} alt="" aria-hidden="true" class="mark" />
            <h3>{service.title}</h3>
            <p>{service.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  h2 {
    margin-top: 14px;
    max-width: 18ch;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 22px;
    margin-top: 48px;
  }

  .card {
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 30px 28px;
    background: var(--paper);
    transition:
      transform 0.18s ease,
      box-shadow 0.18s ease;
  }

  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px -24px rgba(10, 10, 10, 0.32);
  }

  .mark {
    height: 44px;
    width: auto;
    display: block;
    margin-bottom: 16px;
    transition: transform 0.2s ease;
  }

  .card:hover .mark {
    transform: scale(1.12) rotate(-5deg);
  }

  .card h3 {
    margin-bottom: 0.5rem;
  }

  .card p {
    color: var(--ink-soft);
    font-size: 1rem;
  }

  @media (max-width: 880px) {
    .cards {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .card:hover {
      transform: none;
    }

    .card:hover .mark {
      transform: none;
    }
  }
</style>
