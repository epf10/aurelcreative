---
import { Image } from 'astro:assets';
import wordmarkDark from '../assets/logos/AC_Logo_Workmark_Black_1.png';
import wordmarkLight from '../assets/logos/AC_Logo_Workmark_White_1.png';

interface Props {
  height?: number;
  inverse?: boolean;
  loading?: 'eager' | 'lazy';
}

const { height = 32, inverse = false, loading = 'lazy' } = Astro.props;
const wordmark = inverse ? wordmarkLight : wordmarkDark;
const width = Math.round(height * (wordmark.width / wordmark.height));
---

<a class="brand" href="#top" aria-label="Aurel Creative home">
  <Image
    src={wordmark}
    alt="Aurel Creative"
    width={width}
    height={height}
    densities={[1, 2]}
    loading={loading}
  />
</a>

<style>
  .brand {
    display: inline-flex;
    align-items: center;
  }

  .brand img {
    display: block;
  }
</style>
