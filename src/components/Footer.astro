---
import Brand from './Brand.astro';

const year = new Date().getFullYear();
---

<footer>
  <div class="wrap foot">
    <Brand height={26} inverse />
    <small>Aurel Creative &copy; {year}. Digital products for creators.</small>
  </div>
</footer>

<style>
  footer {
    background: var(--ink);
    color: rgba(255, 255, 255, 0.6);
    padding: 46px 0;
  }

  .foot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 18px;
  }

  small {
    font-size: 0.84rem;
  }
</style>
